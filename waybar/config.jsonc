    "format-wifi": "´çź {essid} {signalStrength}%",
    "format-ethernet": "´âü {ifname}",
    "format-disconnected": "´ü▒ Disconnected",
    "tooltip": true
  },

  "battery": {
    "format": "{capacity}% {icon}",
    "format-icons": ["´ëä","´ëâ","´ëé","´ëü","´ëÇ"]
  }
}
