  "layer": "top",
  "position": "top",

  "modules-left": ["sway/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["pulseaudio", "network", "battery"],

  "clock": {
    "format": "{:%Y-%m-%d %H:%M:%S}"
  },

  "pulseaudio": {
    "format": "{volume}% ´ÇĘ",
